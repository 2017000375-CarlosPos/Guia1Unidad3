Algoritmo Lecci30PseintCarlosPos
    Definir num, i, crup Como Entero
    Definir repe Como Logico
    Dimension num[15]
    
    Para i = 1 Hasta 15 Con Paso 1 Hacer
	Escribir "Digite el número ", i, ":"
	Leer num[i]
    FinPara
    
    tieneRepetido <- Falso
    
    Para i = 1 Hasta 14 Con Paso 1 Hacer
	Para crup = i + 1 Hasta 15 Con Paso 1 Hacer
	Si num[i] = num[crup] Entonces
	repe = Verdadero
	FinSi
	FinPara
    FinPara
    
    Si repe Entonces
	Escribir "Existe al menos un número repetido."
    Sino
	Escribir "No hay números repetidos."
    FinSi
FinAlgoritmo
