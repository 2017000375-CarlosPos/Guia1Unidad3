Algoritmo Leccion30Acti2PosPseint
    Definir num, i, mayor, posicion Como Entero
    Dimension num[8]
    
    Para i = 1 Hasta 8 Con Paso 1 Hacer
	Escribir "Digite el número ", i, ":"
	Leer num[i]
    FinPara
    mayor = num[1]
    posicion = 1
    Para i = 1 Hasta 8 Con Paso 1 Hacer
	Si num[i] > mayor Entonces
	mayor = num[i]
	posicion = i
	FinSi
    FinPara
    Escribir "numero mayor del arreglo es: ", mayor
    Escribir "en la posición: ", posicion
FinAlgoritmo
